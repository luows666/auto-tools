# Ignore everything
*

# But keep these file types
!*/*.html
!*.html
!*/*.json
!*.md
!*.txt
!*.yaml
!*.yml
!_config.yml
!.nojekyll
!_pages/

# Keep specific files
!.gitignore
!README.md
!manifest.json
!robots.txt
!sitemap.xml

# Allow new directories for organized HTML files
!card-generators/
!tools/
!tests/

