.claude/
docs/
!memories/
scripts/
bin/
dashboard/
lib/
logs/
node_modules/
projects/
worker/
.github/
presentation/

# Ignore these specific files
.gitattributes
package.json
package-lock.json
Makefile
PROMPT.md
INDEX.md
CLAUDE.md
sw.js
wrangler.toml
